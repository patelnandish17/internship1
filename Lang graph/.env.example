# .env.example — copy to .env and fill in real values

# ── LLM Providers ──────────────────────────────────────────────────────────
GOOGLE_API_KEY=
GITHUB_TOKEN=
GROQ_API_KEY=
SAMBANOVA_API_KEY=
DEEPSEEK_API_KEY=

# ── LangSmith Tracing (optional) ───────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=langgraph-pipeline
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Pipeline Behaviour ─────────────────────────────────────────────────────
OUTPUT_DIR=.          # Directory where golden record JSON/MD files are saved
MAX_RETRIES=3         # Max LLM retry attempts per branch
BATCH_SIZE=20         # Parameters per LLM batch call
CONCURRENCY_LIMIT=3   # Parallel batch calls per branch

# ── API Server ─────────────────────────────────────────────────────────────
API_VERSION=1.0.0
CORS_ORIGINS=["*"]    # JSON array of allowed origins, e.g. ["https://myapp.com"]
